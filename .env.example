# For the web app (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:3001

# For backend / worker / edge functions
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
AI_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# Email (Google SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AI Brain <your-email@gmail.com>

# Public web app URL (used in workspace invite emails)
FRONTEND_URL=https://your-app.vercel.app

# Worker
WORKER_SECRET=generate-a-random-secret
CRON_SECRET=generate-another-random-secret

# Feature flags (comma-separated enabled flags)
FEATURE_FLAGS=shared_memory,analytics
