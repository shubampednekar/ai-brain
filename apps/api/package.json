{
  "name": "@ai-brain/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "vercel-build": "cd ../.. && rm -rf packages/database/dist packages/core/dist packages/database/tsconfig.tsbuildinfo packages/core/tsconfig.tsbuildinfo && pnpm exec tsc -b tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ai-brain/core": "workspace:*",
    "@ai-brain/database": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
