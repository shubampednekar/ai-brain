{
  "name": "@ai-brain/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "vercel-build": "cd ../.. && rm -rf packages/database/dist packages/core/dist packages/database/tsconfig.tsbuildinfo packages/core/tsconfig.tsbuildinfo && pnpm exec tsc -b tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ai-brain/core": "workspace:*",
    "@ai-brain/database": "workspace:*",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@vercel/node": "^3.2.27",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
