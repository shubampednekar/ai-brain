{
  "name": "@ai-brain/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./modules/*": {
      "types": "./dist/modules/*/index.d.ts",
      "import": "./dist/modules/*/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:unit": "vitest run --dir src"
  },
  "dependencies": {
    "@ai-brain/database": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
